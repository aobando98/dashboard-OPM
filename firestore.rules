rules_version = '2';

// ============================================================
//  Reglas de Seguridad de Firestore — CreaTica 3D Dashboard OPM
//
//  Principio: cada usuario solo puede leer, crear, actualizar y
//  eliminar los documentos donde el campo `uid` coincida con
//  su propio request.auth.uid (privacidad total de datos).
//
//  Cómo aplicar estas reglas:
//  1. Ve a https://console.firebase.google.com
//  2. Selecciona tu proyecto → Firestore Database → Rules
//  3. Copia y pega este contenido completo → Publish
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Función auxiliar: valida la estructura de un documento ─
    function camposValidos(data) {
      return data.uid is string
          && data.nombre is string
          && data.nombre.size() > 0
          && data.nombre.size() <= 100
          && data.categoria in ['Filamento PLA', 'Filamento PETG', 'Resina', 'Repuestos', 'Equipos']
          && data.cantidad is number
          && data.cantidad >= 0
          && data.cantidad <= 999999
          && data.costoUnitario is number
          && data.costoUnitario >= 0
          && data.costoUnitario <= 999999
          && data.proveedor is string
          && data.proveedor.size() <= 100
          && data.nivelMinimo is number
          && data.nivelMinimo >= 0
          && data.nivelMinimo <= 999999;
    }

    // ── Colección de inventario ────────────────────────────────
    match /inventario/{docId} {

      // Leer: solo si el documento le pertenece al usuario autenticado
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      // Crear: el nuevo documento DEBE incluir un uid que coincida
      // con el usuario que hace la solicitud, y todos los campos
      // deben cumplir tipos, rangos y la lista blanca de categorías
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && camposValidos(request.resource.data);

      // Actualizar: solo el propietario puede modificar su documento,
      // no puede cambiar el campo uid, y los campos deben seguir
      // siendo válidos tras la actualización
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && camposValidos(request.resource.data);

      // Eliminar: solo el propietario del documento
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // ── Colección de ventas ────────────────────────────────────
    function ventaCamposValidos(data) {
      return data.uid is string
          && data.fecha is string
          && data.fecha.size() == 10
          && data.producto is string
          && data.producto.size() > 0
          && data.producto.size() <= 100
          && data.cliente is string
          && data.cliente.size() <= 100
          && data.cantidad is number
          && data.cantidad >= 1
          && data.cantidad <= 999999
          && data.precioUnitario is number
          && data.precioUnitario >= 0
          && data.precioUnitario <= 999999
          && data.notas is string
          && data.notas.size() <= 200;
    }

    match /ventas/{docId} {
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && ventaCamposValidos(request.resource.data);

      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && ventaCamposValidos(request.resource.data);

      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // Cualquier otra colección está bloqueada por defecto
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
