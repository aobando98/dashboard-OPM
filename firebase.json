{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.git/**",
      "**/.*",
      "firestore.rules",
      "js/firebase-config.example.js",
      "PROMPT_CLAUDE.md",
      "CLAUDE.md",
      "README.md"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options",        "value": "DENY"    },
          { "key": "X-XSS-Protection",       "value": "1; mode=block" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
